{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Rule Notebook Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"${workspaceFolder}/notebooks/rust.cmnb"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "npm: compile"
		}
	]
}
