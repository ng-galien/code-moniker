{
	"name": "code-moniker-notebook",
	"displayName": "Code Moniker Rule Notebook",
	"description": "Learn, author, and test code-moniker check rules interactively as a notebook.",
	"version": "0.1.0",
	"publisher": "code-moniker",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ng-galien/code-moniker.git",
		"directory": "vscode-extension"
	},
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Notebooks",
		"Linters",
		"Education"
	],
	"main": "./dist/extension.js",
	"activationEvents": [
		"onNotebook:code-moniker",
		"onView:codeMoniker.ruleFiles",
		"onView:codeMoniker.catalog"
	],
	"contributes": {
		"notebooks": [
			{
				"type": "code-moniker",
				"displayName": "Code Moniker Rule Notebook",
				"selector": [
					{
						"filenamePattern": "*.cmnb"
					}
				]
			}
		],
		"notebookRenderer": [
			{
				"id": "code-moniker-violations",
				"displayName": "Code Moniker Violations",
				"entrypoint": "./dist/renderer.js",
				"mimeTypes": [
					"application/x-code-moniker-violations+json"
				]
			}
		],
		"languages": [
			{
				"id": "cmrule-toml",
				"aliases": [
					"Code Moniker Rule (TOML)"
				],
				"filenames": [
					".code-moniker.toml"
				],
				"filenamePatterns": [
					"*.fragment.toml"
				],
				"configuration": "./language-configuration.json",
				"icon": {
					"light": "./icons/rule.svg",
					"dark": "./icons/rule.svg"
				}
			},
			{
				"id": "cmnb",
				"aliases": [
					"Code Moniker Notebook"
				],
				"extensions": [
					".cmnb"
				],
				"icon": {
					"light": "./icons/notebook.svg",
					"dark": "./icons/notebook.svg"
				}
			}
		],
		"grammars": [
			{
				"language": "cmrule-toml",
				"scopeName": "source.cmrule-toml",
				"path": "./syntaxes/cmrule-toml.tmLanguage.json"
			},
			{
				"scopeName": "source.cmrule",
				"path": "./syntaxes/cmrule.tmLanguage.json"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "codeMoniker",
					"title": "Code Moniker",
					"icon": "./icons/activity.svg"
				}
			]
		},
		"views": {
			"codeMoniker": [
				{
					"id": "codeMoniker.ruleFiles",
					"name": "Rule Files"
				},
				{
					"id": "codeMoniker.catalog",
					"name": "Catalog"
				}
			]
		},
		"iconThemes": [
			{
				"id": "code-moniker-icons",
				"label": "Code Moniker",
				"path": "./icons/icon-theme.json"
			}
		],
		"commands": [
			{
				"command": "codeMoniker.newNotebook",
				"title": "New Rule Notebook",
				"category": "Code Moniker",
				"icon": "$(notebook)"
			},
			{
				"command": "codeMoniker.openLesson",
				"title": "Open Learning Notebook",
				"category": "Code Moniker",
				"icon": "$(notebook)"
			},
			{
				"command": "codeMoniker.catalog.openEntry",
				"title": "Open Catalog Sample",
				"category": "Code Moniker",
				"icon": "$(notebook)"
			},
			{
				"command": "codeMoniker.catalog.resetEntry",
				"title": "Reset Catalog Sample",
				"category": "Code Moniker",
				"icon": "$(discard)"
			},
			{
				"command": "codeMoniker.catalog.resetActiveEntry",
				"title": "Reset Catalog Sample",
				"category": "Code Moniker",
				"icon": "$(discard)"
			},
			{
				"command": "codeMoniker.catalog.copyToUserCatalog",
				"title": "Copy to User Catalog",
				"category": "Code Moniker",
				"icon": "$(copy)"
			},
			{
				"command": "codeMoniker.catalog.changeView",
				"title": "Catalog View",
				"category": "Code Moniker",
				"icon": "$(list-tree)"
			},
			{
				"command": "codeMoniker.catalog.changeSort",
				"title": "Sort Catalog",
				"category": "Code Moniker",
				"icon": "$(sort-precedence)"
			},
			{
				"command": "codeMoniker.catalog.filter",
				"title": "Filter Catalog",
				"category": "Code Moniker",
				"icon": "$(filter)"
			},
			{
				"command": "codeMoniker.catalog.clearFilters",
				"title": "Clear Catalog Filters",
				"category": "Code Moniker",
				"icon": "$(clear-all)"
			},
			{
				"command": "codeMoniker.catalog.refresh",
				"title": "Refresh Catalog",
				"category": "Code Moniker",
				"icon": "$(refresh)"
			},
			{
				"command": "codeMoniker.catalog.openUserFolder",
				"title": "Open User Catalog Folder",
				"category": "Code Moniker",
				"icon": "$(folder-opened)"
			},
			{
				"command": "codeMoniker.addSampleCell",
				"title": "Add Sample Cell",
				"category": "Code Moniker"
			},
			{
				"command": "codeMoniker.addRuleCell",
				"title": "Add Rule Cell",
				"category": "Code Moniker"
			},
			{
				"command": "codeMoniker.copyRuleToProjectConfig",
				"title": "Copy Rule to Project Config",
				"category": "Code Moniker",
				"icon": "$(copy)"
			},
			{
				"command": "codeMoniker.refreshRuleFiles",
				"title": "Refresh",
				"category": "Code Moniker",
				"icon": "$(refresh)"
			},
			{
				"command": "codeMoniker.openRuleFile",
				"title": "Open Rule File",
				"category": "Code Moniker"
			},
			{
				"command": "codeMoniker.validateRuleFile",
				"title": "Validate Rules",
				"category": "Code Moniker",
				"icon": "$(check)"
			},
			{
				"command": "codeMoniker.runRuleFileOnProject",
				"title": "Run on Project",
				"category": "Code Moniker",
				"icon": "$(play)"
			},
			{
				"command": "codeMoniker.testRuleInNotebook",
				"title": "Test Rule in Notebook",
				"category": "Code Moniker",
				"icon": "$(beaker)"
			},
			{
				"command": "codeMoniker.revealRule",
				"title": "Reveal Rule",
				"category": "Code Moniker"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "codeMoniker.refreshRuleFiles",
					"when": "view == codeMoniker.ruleFiles",
					"group": "navigation"
				},
				{
					"command": "codeMoniker.newNotebook",
					"when": "view == codeMoniker.catalog",
					"group": "navigation"
				},
				{
					"command": "codeMoniker.catalog.refresh",
					"when": "view == codeMoniker.catalog",
					"group": "navigation@1"
				},
				{
					"command": "codeMoniker.catalog.changeView",
					"when": "view == codeMoniker.catalog",
					"group": "navigation@2"
				},
				{
					"command": "codeMoniker.catalog.filter",
					"when": "view == codeMoniker.catalog",
					"group": "navigation@3"
				},
				{
					"command": "codeMoniker.catalog.changeSort",
					"when": "view == codeMoniker.catalog",
					"group": "navigation@4"
				},
				{
					"command": "codeMoniker.catalog.clearFilters",
					"when": "view == codeMoniker.catalog",
					"group": "navigation@5"
				}
			],
			"notebook/title": [
				{
					"command": "codeMoniker.catalog.resetActiveEntry",
					"when": "notebookType == code-moniker && resourceScheme == code-moniker-catalog",
					"group": "navigation"
				}
			],
			"commandPalette": [
				{
					"command": "codeMoniker.catalog.resetActiveEntry",
					"when": "false"
				}
			],
			"notebook/cell/title": [
				{
					"command": "codeMoniker.addRuleCell",
					"when": "notebookType == code-moniker && notebookCellType == code && notebookCellLangId != cmrule-toml",
					"group": "inline@1"
				},
				{
					"command": "codeMoniker.addSampleCell",
					"when": "notebookType == code-moniker && notebookCellType == code",
					"group": "inline@2"
				},
				{
					"command": "codeMoniker.copyRuleToProjectConfig",
					"when": "notebookType == code-moniker && notebookCellLangId == cmrule-toml",
					"group": "inline@3"
				}
			],
			"view/item/context": [
				{
					"command": "codeMoniker.runRuleFileOnProject",
					"when": "view == codeMoniker.ruleFiles && viewItem == cmRuleFile",
					"group": "inline@1"
				},
				{
					"command": "codeMoniker.validateRuleFile",
					"when": "view == codeMoniker.ruleFiles && viewItem == cmRuleFile",
					"group": "inline@2"
				},
				{
					"command": "codeMoniker.openRuleFile",
					"when": "view == codeMoniker.ruleFiles && viewItem == cmRuleFile",
					"group": "1_cm"
				},
				{
					"command": "codeMoniker.validateRuleFile",
					"when": "view == codeMoniker.ruleFiles && viewItem == cmRuleFile",
					"group": "1_cm"
				},
				{
					"command": "codeMoniker.runRuleFileOnProject",
					"when": "view == codeMoniker.ruleFiles && viewItem == cmRuleFile",
					"group": "1_cm"
				},
				{
					"command": "codeMoniker.testRuleInNotebook",
					"when": "view == codeMoniker.ruleFiles && viewItem == cmRule",
					"group": "inline@1"
				},
				{
					"command": "codeMoniker.testRuleInNotebook",
					"when": "view == codeMoniker.ruleFiles && viewItem == cmRule",
					"group": "1_cm"
				},
				{
					"command": "codeMoniker.catalog.openEntry",
					"when": "view == codeMoniker.catalog && viewItem =~ /^cmCatalog.*Entry$/",
					"group": "inline@1"
				},
				{
					"command": "codeMoniker.catalog.resetEntry",
					"when": "view == codeMoniker.catalog && viewItem == cmCatalogBuiltinEntry",
					"group": "inline@2"
				},
				{
					"command": "codeMoniker.catalog.copyToUserCatalog",
					"when": "view == codeMoniker.catalog && viewItem == cmCatalogBuiltinEntry",
					"group": "inline@3"
				},
				{
					"command": "codeMoniker.catalog.openEntry",
					"when": "view == codeMoniker.catalog && viewItem =~ /^cmCatalog.*Rule$/",
					"group": "inline@1"
				},
				{
					"command": "codeMoniker.catalog.copyToUserCatalog",
					"when": "view == codeMoniker.catalog && viewItem == cmCatalogBuiltinRule",
					"group": "inline@2"
				},
				{
					"command": "codeMoniker.catalog.openUserFolder",
					"when": "view == codeMoniker.catalog && viewItem == cmCatalogUserGroup",
					"group": "inline@1"
				},
				{
					"command": "codeMoniker.catalog.openEntry",
					"when": "view == codeMoniker.catalog && viewItem =~ /^cmCatalog.*Entry$/",
					"group": "1_cm"
				},
				{
					"command": "codeMoniker.catalog.resetEntry",
					"when": "view == codeMoniker.catalog && viewItem == cmCatalogBuiltinEntry",
					"group": "1_cm"
				},
				{
					"command": "codeMoniker.catalog.copyToUserCatalog",
					"when": "view == codeMoniker.catalog && viewItem == cmCatalogBuiltinEntry",
					"group": "1_cm"
				},
				{
					"command": "codeMoniker.catalog.openUserFolder",
					"when": "view == codeMoniker.catalog && viewItem == cmCatalogUserGroup",
					"group": "1_cm"
				}
			]
		},
		"configuration": {
			"title": "Code Moniker",
			"properties": {
				"codeMoniker.binaryPath": {
					"type": "string",
					"default": "code-moniker",
					"description": "Path to the code-moniker CLI binary. Defaults to `code-moniker` on PATH, with a fallback to ~/.cargo/bin/code-moniker."
				},
				"codeMoniker.catalog.userFolder": {
					"type": "string",
					"default": ".code-moniker/catalog",
					"description": "Workspace-relative folder that stores editable user catalog notebooks."
				}
			}
		}
	},
	"scripts": {
		"compile": "node esbuild.js",
		"watch": "node esbuild.js --watch",
		"typecheck": "tsc --noEmit",
		"validate": "node scripts/validate-notebooks.mjs",
		"test": "npm run typecheck && npm run validate",
		"vscode:prepublish": "npm run compile"
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"@types/vscode": "^1.85.0",
		"esbuild": "^0.20.0",
		"typescript": "^5.4.0"
	}
}
