{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"lib": [
			"ES2022",
			"DOM"
		],
		"strict": true,
		"jsx": "react-jsx",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"rootDir": ".",
		"types": [
			"node",
			"vscode"
		]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"renderer/**/*.ts"
	]
}
